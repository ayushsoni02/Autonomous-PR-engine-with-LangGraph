# =============================================================================
#  .env  —  Environment Variables for PR Engine
# =============================================================================
#  Copy this file to .env and fill in your real values:
#      cp .env.example .env
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ───────────────────────────────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens
# Required scopes: Contents (R/W), Issues (R), Pull Requests (R/W), Metadata (R)
GITHUB_TOKEN=ghp_...

# ── Docker Sandbox ───────────────────────────────────────────────────────────
# Image name built from docker/Dockerfile.sandbox
SANDBOX_IMAGE_NAME=pr-engine-sandbox:latest

# ── Behaviour ────────────────────────────────────────────────────────────────
MAX_RETRY_COUNT=3

# ── LLM Model ───────────────────────────────────────────────────────────────
# Options: claude-opus-4-5 (best quality), claude-sonnet-4-5 (faster/cheaper)
MODEL_NAME=claude-sonnet-4-20250514

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
